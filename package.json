{
  "name": "rest-api",
  "version": "3.0.1",
  "description": "REST API with Node.js, Express, TypeScript - JWT Auth, CRUD, Testing, Swagger, RBAC, Rate Limiting, File Upload, Email Verification, WebSocket",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration"
  },
  "keywords": ["api", "rest", "express", "typescript", "nodejs", "jest", "testing", "swagger", "rbac", "docker", "websocket", "email"],
  "author": "Mavorynix",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^3.0.3",
    "zod": "^3.22.4",
    "uuid": "^13.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "express-rate-limit": "^7.1.5",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.11",
    "socket.io": "^4.7.4",
    "mime-types": "^2.1.35",
    "sanitize-html": "^2.12.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/mime-types": "^2.1.4",
    "@types/sanitize-html": "^2.11.0",
    "typescript": "^5.3.2",
    "tsx": "^4.6.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.1.1",
    "supertest": "^7.2.2"
  }
}
